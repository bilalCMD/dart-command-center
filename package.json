{
  "name": "dart-command-center",
  "version": "1.0.2",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "electron": "electron .",
    "electron-dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "dist": "next build && electron-builder",
    "dist-win": "next build && electron-builder --win",
    "dist-mac": "next build && electron-builder --mac"
  },
  "dependencies": {
    "@notionhq/client": "^2.2.0",
    "@paymoapp/active-window": "^2.1.4",
    "@prisma/client": "^5.18.0",
    "@supabase/supabase-js": "^2.105.3",
    "bcryptjs": "^2.4.3",
    "date-fns": "^3.6.0",
    "lucide-react": "^1.9.0",
    "next": "^14.2.0",
    "next-auth": "^4.24.0",
    "nodemailer": "^7.0.13",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "ws": "^8.20.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "prisma": "^5.18.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "io.dartmarketing.commandcenter",
    "productName": "Dart Command Center",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "category": "public.app-category.business"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Dart Command Center"
    }
  }
}
