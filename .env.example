# ═══ Dart Command Center — Environment Variables ═══
# Copy this to .env.local and fill in real values

# Supabase (Database + Auth)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth (GSuite login)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Notion API (read-only task sync)
NOTION_API_KEY="your-notion-internal-integration-token"
NOTION_DATABASE_ID="your-tasks-database-id"

# App Config
NEXT_PUBLIC_APP_URL="http://localhost:3000"
